<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Development: Allow cleartext (HTTP) for all local IPs and domains -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Allow HTTP for any local/development address -->
        <domain includeSubdomains="true">192.168.1.119</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Add wildcard for all local networks -->
        <domain includeSubdomains="true">*.local</domain>
    </domain-config>

    <!-- Catch-all: Allow cleartext for development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">.</domain>
    </domain-config>
</network-security-config>

